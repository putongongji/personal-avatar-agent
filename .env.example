# MiniMax OpenAI-compatible Chat Completions API.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.7

# SiliconFlow OpenAI-compatible Embeddings API.
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3
CLASSIFICATION_MODEL=Qwen/Qwen3-8B
CLASSIFICATION_FALLBACK_MODELS=Qwen/Qwen2.5-7B-Instruct

# Admin login. Do not commit real passwords.
ADMIN_EMAIL=
ADMIN_PASSWORD=
SESSION_SECRET=

# Optional: override source paths in knowledge/sources/source-registry.json.
# Example: CAREER_ARCHIVE_PATH=~/无用/AREA/职业生涯/职业生涯全景档案-按公司产品线.md
CAREER_ARCHIVE_PATH=
